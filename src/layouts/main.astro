---
import '../styles/global.css';

interface Props {
  content: {
    title: string;
    description?: string;
  };
}

const { content } = Astro.props;
---

<!DOCTYPE html>
<html lang={Astro.currentLocale || 'de'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={content.description || 'WunderweltDE'} />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Andika:wght@400;700&family=Atkinson+Hyperlegible:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{content.title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
